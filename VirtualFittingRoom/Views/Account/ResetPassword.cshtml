@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-shell">
    <section class="auth-copy">
        <span class="eyebrow">Security</span>
        <h1>Choose a new password</h1>
        <p>Set a fresh password, then return to the sign-in page and continue your fitting workflow.</p>
    </section>

    <form asp-action="ResetPassword" method="post" class="auth-card">
        <input type="hidden" name="token" value="@ViewBag.Token" />

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <div class="mb-3">
            <label class="form-label">New Password</label>
            <input name="Password" type="password" class="form-control" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Confirm Password</label>
            <input name="ConfirmPassword" type="password" class="form-control" required />
        </div>

        <button type="submit" class="btn btn-brand w-100">
            Reset Password
        </button>
    </form>
</div>
