@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-shell">
    <section class="auth-copy">
        <span class="eyebrow">Recovery</span>
        <h1>Reset account access</h1>
        <p>Enter the email linked to your fitting room account and we will send a reset link.</p>
    </section>

    <form asp-action="ForgotPassword" method="post" class="auth-card">
        <label class="form-label">Email</label>
        <input name="Email"
               type="email"
               class="form-control"
               placeholder="Enter your email"
               required />

        <button class="btn btn-brand mt-3 w-100">
            Send Reset Link
        </button>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-info mt-3 mb-0">
                @ViewBag.Message
            </div>
        }
    </form>
</div>
