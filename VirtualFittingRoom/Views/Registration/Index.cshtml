@model VirtualFittingRoom.Models.UserMeasurement

@{
    ViewData["Title"] = "Sign Up";
}

<div class="auth-showcase auth-showcase-signup auth-visual-shell">
    <section class="auth-copy">
        <span class="eyebrow">Virtual Fitting Room</span>
        <h1>Create your unique style with artificial intelligence.</h1>
        <p>Join now and start your journey to the perfect fit.</p>
    </section>

    <form asp-action="Index" method="post" class="auth-card auth-card-wide auth-glass-card">
        <span class="auth-kicker">Sign Up</span>
        <h2>Create your account</h2>
        <div asp-validation-summary="All" class="text-danger mb-3"></div>

        <div class="auth-field">
            <label class="form-label">Full Name</label>
            <div class="auth-input-wrap">
                <i class="bi bi-person"></i>
                <input asp-for="FullName" class="form-control" placeholder="Enter your full name" />
            </div>
            <span asp-validation-for="FullName" class="text-danger"></span>
        </div>

        <div class="auth-field">
            <label class="form-label">Email</label>
            <div class="auth-input-wrap">
                <i class="bi bi-envelope"></i>
                <input asp-for="Email" class="form-control" placeholder="name@example.com" />
            </div>
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="auth-field">
            <label class="form-label">Password</label>
            <div class="password-field auth-input-wrap">
                <i class="bi bi-lock"></i>
                <input asp-for="Password"
                       type="password"
                       class="form-control password-input"
                       id="password"
                       placeholder="Create a password"
                       autocomplete="new-password" />
                <button type="button" class="password-toggle" data-password-toggle aria-label="Show password">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <span asp-validation-for="Password" class="text-danger"></span>
        </div>

        <div class="auth-field">
            <label class="form-label">Confirm Password</label>
            <div class="password-field auth-input-wrap">
                <i class="bi bi-lock"></i>
                <input asp-for="ConfirmPassword"
                       type="password"
                       class="form-control password-input"
                       id="confirmPassword"
                       placeholder="Confirm your password"
                       autocomplete="new-password" />
                <button type="button" class="password-toggle" data-password-toggle aria-label="Show password">
                    <i class="bi bi-eye"></i>
                </button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
        </div>

        <input asp-for="PhoneNumber" type="hidden" value="0000000000" />
        <input asp-for="Gender" type="hidden" value="Unspecified" />
        <input asp-for="Age" type="hidden" value="18" />
        <input asp-for="Weight" type="hidden" value="0" />
        <input asp-for="Height" type="hidden" value="0" />

        <label class="terms-check">
            <input type="checkbox" required />
            <span>I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></span>
        </label>

        <button type="submit" class="btn btn-brand w-100 mt-3">Sign Up</button>

        <div class="social-auth">
            <div class="social-divider"><span>Sign up with</span></div>
            <div class="social-buttons" aria-label="Social sign up options">
                <a asp-controller="Account"
                   asp-action="ExternalLogin"
                   asp-route-provider="Google"
                   asp-route-returnUrl="/TryOn"
                   class="social-btn google"
                   aria-label="Sign up with Google">
                    <i class="bi bi-google"></i>
                    <span>Google</span>
                </a>
                <a asp-controller="Account"
                   asp-action="ExternalLogin"
                   asp-route-provider="Facebook"
                   asp-route-returnUrl="/TryOn"
                   class="social-btn facebook"
                   aria-label="Sign up with Facebook">
                    <i class="bi bi-facebook"></i>
                    <span>Facebook</span>
                </a>
                <a asp-controller="Account"
                   asp-action="ExternalLogin"
                   asp-route-provider="Apple"
                   asp-route-returnUrl="/TryOn"
                   class="social-btn apple"
                   aria-label="Sign up with iCloud">
                    <i class="bi bi-apple"></i>
                    <span>Apple</span>
                </a>
            </div>
        </div>

        <p class="auth-switch">
            Already have an account?
            <a asp-controller="Account" asp-action="Login" class="inline-link">Sign in</a>
        </p>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
