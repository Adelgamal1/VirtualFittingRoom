@{
    ViewData["Title"] = "Studio";
}

<section class="studio-home">
    <div class="studio-home-copy">
        <span class="eyebrow">Virtual Fitting Room</span>
        <h1>Studio</h1>
        <p>
            Capture the customer image, upload the garment, then continue the fitting flow from one clean home screen.
        </p>
    </div>

    <div class="studio-home-meta">
        <div class="meta-card">
            <strong>Camera Ready</strong>
            <span>Phone camera on mobile, laptop webcam on desktop.</span>
        </div>
        <div class="meta-card">
            <strong>Dual Upload</strong>
            <span>Customer pose plus clothing image in the same session.</span>
        </div>
        <div class="meta-card">
            <strong>Session Flow</strong>
            <span>Gender, category, capture, then continue to fitting history.</span>
        </div>
    </div>
</section>

<partial name="_TryOnStudio" />
