<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@500;600;700;800&family=Source+Sans+3:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["action"]?.ToString();
        var isLoggedIn = Context.Session.GetInt32("UserId") != null;
        var isLoginPage = currentController == "Account" && currentAction == "Login";
        var isSignupPage = currentController == "Registration" && currentAction == "Index";
    }

    <div class="site-bg"></div>

    <nav class="navbar site-navbar">
        <div class="container app-shell nav-inner">
            <a asp-controller="Home" asp-action="Index" class="brand-mark text-decoration-none">
                <span class="brand-dot"></span>
                <span>Virtual Fitting Room</span>
            </a>

            <div class="nav-links">
                @if (isLoggedIn)
                {
                    <a asp-controller="TryOn" asp-action="History" class="nav-pill filled">History</a>
                }
                else if (isSignupPage)
                {
                    <a asp-controller="Account" asp-action="Login" class="nav-pill filled">Sign In</a>
                }
                else if (!isLoginPage)
                {
                    <a asp-controller="Account" asp-action="Login" class="nav-pill">Sign In</a>
                    <a asp-controller="Registration" asp-action="Index" class="nav-pill filled">Sign Up</a>
                }
            </div>
        </div>
    </nav>

    <main class="container app-shell mt-4">
        @RenderBody()
    </main>

    <script src="~/js/site.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
